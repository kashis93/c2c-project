"use strict";(self.webpackChunk_N_E=self.webpackChunk_N_E||[]).push([[6172],{3405:(e,o,i)=>{i.d(o,{A:()=>r});var n=i(7876);i(4232);let r=function(){return(0,n.jsx)("div",{style:{minHeight:"130px",backgroundImage:"url('/Images/3.jpg')",backgroundSize:"cover",backgroundPosition:"center"}})}},3715:(e,o,i)=>{i.d(o,{iy:()=>A,tb:()=>p});let n={id:"grievance-cell",name:"Grievance Redressal Committee",description:"The Grievance Redressal Committee is dedicated to addressing and resolving grievances of students, faculty, and staff in a fair and transparent manner. It ensures a healthy and harmonious environment within the institute by providing a platform for redressal of complaints.",members:[{srNo:1,name:"Prof. (Dr.) M. C. Chudasama",designation:"Professor, Electrical Engineering",position:"Convener"},{srNo:2,name:"Prof. G. H. Bun",designation:"Head of Dept., Environment Engineering",position:"Convener"},{srNo:3,name:"Prof. Yamini Patel",designation:"Associate Professor, Applied Mechanics",position:"Convener"}]},r={id:"anti-ragging",name:"Anti-Ragging Committee and Squad",description:"The Anti-Ragging Committee and Squad play a crucial role in ensuring the safety and well-being of students by preventing and addressing incidents of ragging. The committee implements strict anti-ragging policies and conducts awareness programs.",members:[{srNo:1,name:"Prof. R. M. Jain",designation:"Professor, Civil Engineering",position:"Convener"},{srNo:2,name:"Prof. H. A. Saiyad",designation:"Associate Professor, Environment Engineering",position:"Co-convener"},{srNo:3,name:"Prof. Dipesh Makwana",designation:"Associate Professor, Instrumentation and Control Engineering",position:"Member"},{srNo:4,name:"Hostel Rector",designation:"LDCE",position:"Member"},{srNo:5,name:"Prof. Z. B. Parekh",designation:"Assi. Prof, Electrical Engineering",position:"Member"},{srNo:6,name:"Prof. Hardik Tank",designation:"Assistant Professor, Electronics and Communication Engineering",position:"Member"},{srNo:7,name:"Mr. Akhilkumar Jaiswal",designation:"BE Sem 5 (Civil Engineering)",position:"Boys Representative"},{srNo:8,name:"Ms. Kashish Tanna",designation:"BE Sem 5 (Electrical Engineering)",position:"Girls Representative"}]},s={id:"girls-hostel",name:"Girls Hostel Management Committee",description:"The Girls Hostel Management Committee oversees the administration and welfare of the girls' hostel. It ensures a safe, comfortable, and conducive living environment for female students.",members:[{srNo:1,name:"Prof. Rupande N. Desai",designation:"Asso. Prof, Rubber Technology",position:"Chairperson"},{srNo:2,name:"Prof. Pinky J. Brahmbhatt",designation:"Asso. Prof, Electronics and Communication Engineering",position:"Member"},{srNo:3,name:"Prof. Poonam I. Modi",designation:"Assi. Prof, Applied Mechanics",position:"Member"},{srNo:4,name:"Prof. Beena B. Patel",designation:"Assi. Prof, Environment Engineering",position:"Member Secretary"}]},a={id:"internal-complaint",name:"Internal Complaint Committee",description:"The Internal Complaint Committee is responsible for addressing complaints related to sexual harassment and ensuring a safe campus for all. It follows statutory guidelines and provides a confidential platform for complainants.",hasContactDetails:!0,members:[{srNo:1,name:"Dr. Komal G. Dave",designation:"Prof. Mechanical Engineering",position:"Presiding officer",contactDetails:{phone:"9376768504",email:"dave_komal123@ldce.ac.in"}},{srNo:2,name:"Dr. Rupande N. Desai",designation:"Asso. Prof. Rubber Technology",position:"Member",contactDetails:{phone:"9426033067",email:"rupandendesai@ldce.ac.in"}},{srNo:3,name:"Prof. Binita Vyas",designation:"Asso. Prof. Applied Mechanics",position:"Member",contactDetails:{phone:"9825603310",email:"binita.vyas@ldce.ac.in"}},{srNo:4,name:"Dr. Zenifar B Parekh",designation:"Assi. Prof. Electrical Engineering",position:"Member",contactDetails:{phone:"9879126838",email:"zbp@ldce.ac.in"}},{srNo:5,name:"Ms. Amisha A. Patel",designation:"Administrative Officer",position:"Non-teaching Member",contactDetails:{phone:"9974046769",email:"adminofficer@ldce.ac.in"}},{srNo:6,name:"Ms. Tejal K. Patel",designation:"Computer Operator",position:"Non-teaching Member",contactDetails:{phone:"9426768069",email:"tgb@ldce.ac.in"}},{srNo:7,name:"Ms. Gurneetkaur Baldevsingh Chahal",designation:"Student (BE SEM 7), Electrical Engineering",position:"Student Member",contactDetails:{phone:"9429778468",email:"chahal7781@gmail.com"}},{srNo:8,name:"Ms. Apaara Mehta",designation:"Student (BE SEM 7), Computer Engineering",position:"Student Member",contactDetails:{phone:"7359255372",email:"apaaramehta202@gmail.com"}},{srNo:9,name:"Dr. Meera A. Vasani",designation:"Assi. Prof. English (IITRAM)",position:"Member",contactDetails:{phone:"9898340840",email:"drmeeravasani@gmail.com"}}],additionalInfo:"Functions of this cell are to:\n1. Provide protection to girl students and women against sexual harassment on campus\n2. To provide redressal mechanism for complaints related to sexual harassment at the work place",helplineInfo:{phone:"9879126838",email:"icc_harassment@ldce.ac.in",description:"24 X 7 Mobile Helpline"}};var t=i(8330);let P={id:"physically-handicapped-grievance",name:"Physically Handicapped Grievance Redressal Cell",description:"The Physically Handicapped Grievance Redressal Cell is dedicated to addressing the specific needs and concerns of physically challenged students, faculty, and staff. It ensures accessibility, equal opportunities, and provides a platform for resolving grievances related to physical barriers and discrimination.",members:[{srNo:1,name:"Dr. C. S. Sanghavi",designation:"Professor, Applied Mechanics",position:"Member"},{srNo:2,name:"Prof. R. M. Jain",designation:"Professor, Civil Engineering",position:"Member"},{srNo:3,name:"Dr. Jyoti Iyer",designation:"Professor, Electrical Engineering",position:"Member"},{srNo:4,name:"Dr. R. N. Desai",designation:"Assoc. Professor, Rubber Technology",position:"Member"},{srNo:5,name:"Dr. D. V. Bihola",designation:"Assi. Professor, Textile Technology",position:"Member"}]},f={id:"women-development-cell",name:"Women Development Cell Committee",description:"Vision: Maintaining and strengthening the status of Women and creating wider gender sensitivity so as to facilitate a congenial working environment. Mission: To create awareness of feminine potential and train women to acquire wide range of skills and knowledge. To develop and increase their social, economic and intellectual capacities for peace, security and prosperity of mankind.",members:[{srNo:1,name:"Dr. Komal G. Dave",designation:"Prof. Mechanical Engineering",position:"Presiding Officer",contactDetails:{email:"dave_komal123@ldce.ac.in"}},{srNo:2,name:"Dr. Rupande N. Desai",designation:"Asso. Prof. Rubber Technology",position:"Convener",contactDetails:{email:"rupandendesai@ldce.ac.in"}},{srNo:3,name:"Prof. Binita Vyas",designation:"Asso. Prof. Applied Mechanics",position:"Convener",contactDetails:{email:"binitavyas@yahoo.com"}},{srNo:4,name:"Dr. Zenifar B Parekh",designation:"Assi. Prof. Electrical Engineering",position:"Member",contactDetails:{email:"zbp@ldce.ac.in"}},{srNo:5,name:"Prof. Poonam Modi",designation:"Assi. Prof. Applied Mechanics",position:"Member",contactDetails:{email:"poonammodi@ldce.ac.in"}},{srNo:6,name:"Prof. Amita Shah",designation:"Assi. Prof. Computer Engineering",position:"Member",contactDetails:{email:"amitashah@ldce.ac.in"}},{srNo:7,name:"Prof. Manisha Patel",designation:"Assi. Prof. Inst. & Control Engineering",position:"Member",contactDetails:{email:"m71074@gmail.com"}},{srNo:8,name:"Prof. Niketa Patel",designation:"Assi. Prof. Mechanical Engineering",position:"Member",contactDetails:{email:"nikitapatel1977@gmail.com"}},{srNo:9,name:"Prof. Vaishali Adhwaryu",designation:"Assi. Prof. Science and Humanities",position:"Member",contactDetails:{email:"vaishali.adhwaryu@ldce.ac.in"}},{srNo:10,name:"Prof. Bina Patel",designation:"Assi. Prof. Environment Engineering",position:"Member",contactDetails:{email:"binapatel27@gmail.com"}}],hasContactDetails:!0},c={id:"sc-st-cell",name:"SC/ST Cell Committee",description:"The SC/ST Cell Committee is dedicated to ensuring the welfare and addressing the concerns of Scheduled Caste and Scheduled Tribe students, faculty, and staff. It provides support, guidance, and ensures equal opportunities while addressing any grievances related to discrimination or other issues faced by the SC/ST community.",members:[{srNo:1,name:"Prof. Dipesh H. Makwana",designation:"Associate Professor, Instrumentation & Control Engineering",position:"Convener"},{srNo:2,name:"Prof. Ramesh Damor",designation:"Associate Professor, Science and Humanities",position:"Co-Convener"},{srNo:3,name:"Prof. Swati J. Patel",designation:"Assistant Professor, Mechanical Engineering",position:"Member"},{srNo:4,name:"Prof. Mayur M Makwana",designation:"Assistant Professor, Mechanical Engineering",position:"Member"},{srNo:5,name:"Prof. Piyush S. Patel",designation:"Assistant Professor, Chemical Engineering",position:"Member"}]},l={id:"rti-committee",name:"RTI Committee",description:"The Right to Information (RTI) Committee ensures transparency and accountability in the institution's functioning. It facilitates the implementation of the RTI Act, 2005, and provides citizens with access to information held by the institute while maintaining procedural compliance and timely responses to RTI applications.",members:[{srNo:1,name:"Dr. N. N. Bhuptani",designation:"Principal",position:"Appellate Authority"},{srNo:2,name:"Prof. G. H. Bun",designation:"Head of Dept., Environment Engineering",position:"Public Information Officer"},{srNo:3,name:"Smt. A. A. Patel",designation:"Admin. Officer",position:"Assistant Public Information Officer"}]},m={id:"iqac",name:"Internal Quality Assurance Cell (IQAC)",description:"The Internal Quality Assurance Cell (IQAC) is responsible for developing a system for conscious, consistent and catalytic improvement in the overall performance of the institution. It facilitates quality enhancement and sustenance measures through institutionalizing best practices, promoting innovative teaching-learning processes, and ensuring continuous monitoring and evaluation of academic and administrative activities.",members:[{srNo:1,name:"Prof. S. K. Patel",designation:"Professor, Science and Humanities",position:"Convener"},{srNo:2,name:"Prof. N. V. Sinha",designation:"Associate Professor, Electrical Engineering",position:"Convener"},{srNo:3,name:"Prof. Atul B Patel",designation:"Associate Professor, Science and Humanities",position:"Convener"},{srNo:4,name:"Prof. Irfan Siddiqui",designation:"Assistant Professor, Electrical Engineering",position:"Member"},{srNo:5,name:"Prof. S J Padhiyar",designation:"Assistant Professor, Rubber Technology",position:"Member"},{srNo:6,name:"Prof. S. N. Patel",designation:"Assistant Professor, Automobile Engineering",position:"Member"},{srNo:7,name:"Prof. Jaydev Patel",designation:"Assistant Professor, Science and Humanities",position:"Member"},{srNo:8,name:"Prof. Harshal Patel",designation:"Assistant Professor, Biomedical Engineering",position:"Member"}]},d={id:"ssip-committee",name:"SSIP Committee",description:"The Student Startup and Innovation Policy (SSIP) Committee promotes entrepreneurship and innovation among students by facilitating startup initiatives, providing mentorship, and creating an ecosystem that encourages innovative thinking and business development within the institute.",members:[{srNo:1,name:"Dr. Manish Thakker",designation:"Professor, Instrumentation and Control Engineering",position:"Coordinator"},{srNo:2,name:"Dr. C. H. Vithalani",designation:"Professor, Electronics and Communication Engineering",position:"Coordinator"},{srNo:3,name:"Dr. Chirag Thaker",designation:"Professor, Computer Engineering",position:"Coordinator"},{srNo:4,name:"Dr. Shital Amin",designation:"Associate Professor, Chemical Engineering",position:"Member"},{srNo:5,n